defwidget "My Widget" {

  var t : "BgeWdgtTime";
  var box : "GtkBox";

  var radius : "gdouble";
  var coords : "GraphenePoint";

  init {
    set t = #o:"BgeWdgtTime"(notify-msec = #i:"guint"(5););
    
    set box = #ch:"GtkBox":""(
      _ = #ch:"GtkLabel":""(label="start";);
      _ = #ch:"GtkLabel":""(label="center";
                            hexpand=true;);
      _ = #ch:"GtkLabel":""(label="end";);
    );

    set radius = 100.0;
    set coords = #point(#eval(radius*cos(2.0*#(t:time))),
                        #eval(radius*sin(2.0*#(t:time))));
    
    %snapshot = {
      save {
        move translate(#point(200.0, 200.0));
        move translate(coords);
        add color(#rgba("orange"), #rect(-50.0,-50.0,100.0,100.0));
      }
    }
  }

  state@default "d" = {
    set radius = 100.0;
    transition radius linear 1.0;
  }

  state "s" = {
    set radius = 200.0;
    transition radius linear 2.0;
  }
}
