defwidget "My Widget" {

  var t : "BgeWdgtTime";

  state@default "default" = {
    t = #o:"BgeWdgtTime"(notify-msec = #i:"guint"(5););
    
    %snapshot = {
      save {
        move translate(#point(200.0, 200.0));
        move translate(#point(#eval(100.0*cos(2.0*#(t:time))),
                              #eval(100.0*sin(2.0*#(t:time)))));
        add color(#rgba("orange"), #rect(-50.0,-50.0,100.0,100.0));
      }
    }
  }
}
