defwidget "My Widget" {

  child "scale" = "GtkScale";
  var "r" = "gdouble";

  state@default "default" = {
    var "r" = scale:adjustment:value;
    %snapshot = {
      move translate(#point(10.0, 10.0));
      with rounded-clip(
          #rect(0.0,0.0,300.0,300.0),
          #size(r, r),#size(r, r),
          #size(r, r),#size(r, r),) {
        add linear-gradient(
           #rect(0.0,0.0,300.0,300.0),
           #point(0.0,0.0),
           #point(0.0,300.0),
           
           0.0, #rgba("#5BCEFA"),
           0.2, #rgba("#5BCEFA"),
           
           0.2, #rgba("#F5A9B8"),
           0.4, #rgba("#F5A9B8"),
           
           0.4, #rgba("#FFFFFF"),
           0.6, #rgba("#FFFFFF"),
           
           0.6, #rgba("#F5A9B8"),
           0.8, #rgba("#F5A9B8"),
           
           0.8, #rgba("#5BCEFA"),
           1.0, #rgba("#5BCEFA"),
        );
      }
    }
  }
}
