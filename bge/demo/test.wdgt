defwidget "My Widget" {

  var progress-bar : "GtkProgressBar";
  var fraction : "gdouble";
  
  var radius : "gdouble";
  var corner : "GrapheneSize";
  var rect : "GrapheneRect";
  

  init {
    set progress-bar = #ch:"GtkProgressBar":""(
      fraction = fraction;
    );
    set rect = #rect(-50.0,-50.0,100.0,100.0);
    set corner = #size(radius, radius);
    
    %snapshot = {
      save {
        move translate(#point(200.0, 200.0));
        with rounded-clip(rect, corner, corner, corner, corner) {
          add color(#rgba("orange"), rect);
        }
      }
    }
  }

  state@default "d" = {
    set fraction = 0.0;
    transition fraction ease-in 3.0;
    
    set radius = 10.0;
    transition radius ease 0.4;
  }

  state "s" = {
    set fraction = 1.0;
    transition fraction ease-out 2.0;
    
    set radius = 50.0;
    transition radius ease 0.2;
  }
}
