defwidget "My Widget" {

  child scale : "GtkScale";
  var t : "BgeWdgtTime";
  
  var r : "gdouble";
  var corner : "GrapheneSize";

  state@default "default" = {
    t = #o:"BgeWdgtTime"(notify-msec = #i:"guint"(30););
    
    scale:adjustment = #o:"GtkAdjustment"(
      lower = 0.0;
      value = 50.0;
      upper = 100.0;
    );
    scale:valign = #e:"GtkAlign"(end);

    r = #eval(sin(#(t:time))*25.0);
    corner = #size(r, r);
    
    %snapshot = {
      save {
        move translate(#point(200.0, 200.0));
        move rotate(r);
        add color(#rgba("orange"), #rect(-50.0,-50.0,100.0,100.0));
      }
    }
  }
}
