defwidget "My Widget" {

  var t : "BgeWdgtTime";

  child scale : "GtkScale";
  child progress : "GtkProgressBar";
  child overlay : "GtkOverlay";

  state@default "default" = {
    set t = #o:"BgeWdgtTime"(notify-msec = #i:"guint"(5););
    set scale:valign, progress:valign = #e:"GtkAlign"(start), #e:"GtkAlign"(end);

    set scale:adjustment:lower = 0.0;
    set scale:adjustment:upper = 1.0;
    
    set progress:fraction = #eval(0.5+sin(#(t:time))/2.0);

    set scale:adjustment:value = #eval(1.0-#(progress:fraction));

    set overlay:child = #o:"GtkBox"(
      %child() #o:"GtkLabel"(label = "heyyyy";);
    );


    %snapshot = {
      save {
        move translate(#point(200.0, 200.0));
        move translate(#point(#eval(100.0*cos(2.0*#(t:time))),
                              #eval(100.0*sin(2.0*#(t:time)))));
        add color(#rgba("orange"), #rect(-50.0,-50.0,100.0,100.0));
      }
    }
  }
}
