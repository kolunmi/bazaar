defwidget "My Widget" {
  child "btn" = "GtkLabel";
  state@default "default" = {
    child "btn":label = "default";
    %snapshot = {
      add color(#rgba("#ff6677"), #rect(20.0, 30.0, 50.0, 50.0));
      add color(#rgba("#ff6677"), #rect(50.0, 70.0, 100.0, 50.0));
    }
  }
  state "other" = {
    child "btn":label = "other";
    %snapshot = {
      move translate(#point(50.0, 60.0)) {}
    }
  }
}
