defwidget "My Widget" {

  child scale : "GtkScale";
  var r : "gdouble";
  var corner : "GrapheneSize";

  state@default "default" = {
    scale:adjustment = #o:"GtkAdjustment"(
      lower = 0.0;
      value = 50.0;
      upper = 100.0;
    );
    scale:valign = #e:"GtkAlign"(end);

    r = #eval(2.0*1.0+ #(scale:adjustment:value));
    corner = #size(r, r);
    
    %snapshot = {
      move translate(#point(10.0, 10.0));
      with rounded-clip(
          #rect(0.0,0.0,300.0,300.0),
          corner,corner,
          corner,corner,) {
        add linear-gradient(
           #rect(0.0,0.0,300.0,300.0),
           #point(0.0,0.0),
           #point(0.0,300.0),
           
           0.0, #rgba("#5BCEFA"),
           0.2, #rgba("#5BCEFA"),
           
           0.2, #rgba("#F5A9B8"),
           0.4, #rgba("#F5A9B8"),
           
           0.4, #rgba("#FFFFFF"),
           0.6, #rgba("#FFFFFF"),
           
           0.6, #rgba("#F5A9B8"),
           0.8, #rgba("#F5A9B8"),
           
           0.8, #rgba("#5BCEFA"),
           1.0, #rgba("#5BCEFA"),
        );
      }
    }
  }
}
