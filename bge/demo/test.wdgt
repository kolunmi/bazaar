defwidget "My Widget" {
  child "btn" = "GtkLabel";
  state@default "default" = {
    child "btn":label = "default";
    %snapshot = {
      save {
        move translate(#point(100.0, 100.0));
        add color(#rgba("#ff6677"), #rect(0.0, 0.0, 50.0, 50.0));
      }
      add color(#rgba("#66ff77"), #rect(0.0, 0.0, 50.0, 50.0));
    }
  }
  state "other" = {
    child "btn":label = "other";
    %snapshot = {
      move translate(#point(50.0, 60.0));
    }
  }
}
